# API base URL for frontend fetch calls.
# Leave empty on the server: same-origin (/api/...) works for LAN and public.
# Nginx must proxy /api/ and /media/ to Django.
VITE_API_BASE_URL=

# Local dev only: Vite proxies /api/ and /media/ to this Django URL
VITE_DEV_API_PROXY_TARGET=http://127.0.0.1:8000
